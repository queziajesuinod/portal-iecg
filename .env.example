# Ambiente
NODE_ENV=development

# Banco de Dados PostgreSQL
DB_USER=root
DB_PASS=sua_senha_aqui
DB_NAME=iecg_bd
DB_HOST=localhost
DB_PORT=5432
DB_SCHEMA=dev_iecg

# JWT
JWT_SECRET=sua_chave_secreta_jwt

# API URL
REACT_APP_API_URL=http://localhost:3005

# Cielo E-commerce API
# Obtenha suas credenciais em: https://cadastrosandbox.cieloecommerce.cielo.com.br/
CIELO_MERCHANT_ID=seu_merchant_id_aqui
CIELO_MERCHANT_KEY=sua_merchant_key_aqui
CIELO_ENVIRONMENT=sandbox
# Valores possíveis: 'sandbox' (testes) ou 'production' (produção)

# Evolution API (WhatsApp)
# Configure sua instância da Evolution API para envio de notificações
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key_aqui
EVOLUTION_INSTANCE_NAME=iecg-events

# ===== SMTP (envio de email pra notificacoes) =====
# Templates com channel='email' usam essas credenciais.
# Provedores comuns:
#   Gmail/Workspace:   host=smtp.gmail.com port=587 secure=false (precisa app password)
#   Outlook/Microsoft: host=smtp.office365.com port=587 secure=false
#   SendGrid:          host=smtp.sendgrid.net port=587 secure=false (user=apikey)
#   Resend:            host=smtp.resend.com port=587 secure=false (user=resend)
#   AWS SES:           host=email-smtp.<region>.amazonaws.com port=587 secure=false
#   Hostinger:         host=smtp.hostinger.com port=465 secure=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Email que aparece como remetente (default: SMTP_USER se vazio)
SMTP_FROM=contato@iecg.com.br
SMTP_FROM_NAME=Portal IECG
# Email pra Reply-To (deixe vazio se quiser usar SMTP_FROM)
SMTP_REPLY_TO=
# URL publica do backend (usada no pixel de rastreamento de abertura de email).
# DEVE ser acessivel pela internet em producao (ex: https://portal.iecg.com.br).
# Se vazio, cai no REACT_APP_API_URL; em localhost o rastreamento de leitura nao funciona.
PUBLIC_BASE_URL=

# Frontend URL (para links nas notificações)
FRONTEND_URL=http://localhost:3000

# Observações:
# - Para ambiente de testes (sandbox), use as credenciais fornecidas pela Cielo Sandbox
# - Para produção, solicite credenciais reais no portal da Cielo
# - Configure a Evolution API para receber notificações via WhatsApp
# - Nunca commite este arquivo com credenciais reais no repositório

# Ef� Pay
EFI_ENVIRONMENT=sandbox
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_CERTIFICATE_PATH=path/para/certificado.pfx  # ou use EFI_CERTIFICATE_BASE64 para certificados em base64
EFI_PEM_KEY_PATH=path/para/chave.pem  # ou use EFI_PEM_KEY_BASE64 para chave em base64
EFI_PARTNER_TOKEN=
EFI_CACHE_TOKEN=true
EFI_VALIDATE_MTLS=true
EFI_COMMISSION_PERCENT=1.5
EFI_PIX_PAGADOR_CHAVE=
EFI_PIX_FAVORECIDO_CHAVE=
EFI_PIX_INFO_PAGADOR=Comiss�o Ef�
EFI_PIX_ID_PREFIX=efi-commission


# Redis (Cache)
# URL de conexão do Redis para cache de performance
# Deixe vazio ou comente para desabilitar o cache (sistema funcionará normalmente)
REDIS_URL=redis://localhost:6379

# ===== Modulo de transcricao de videos do YouTube =====
# Credenciais OAuth do Google (um par para o portal inteiro, atende N canais)
# Crie em https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client IDs)
# Habilite a "YouTube Data API v3" no projeto antes
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://portal.iecg.com.br/api/public/youtube/oauth/callback

# Chave para criptografar refresh tokens de canais no banco (AES-256-GCM)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# Anthropic Claude (usado para gerar resumos das transcricoes)
ANTHROPIC_API_KEY=

# ===== Pipeline de transcricao =====
# Fluxo:
#   1. Sync com YouTube descobre novos videos (so metadados)
#   2. Admin faz upload do audio MP3/M4A/WAV via botao na UI
#   3. Whisper local (faster-whisper) transcreve o arquivo
#   4. Claude gera resumo + bullets + SEO
#   5. Webhook opcional recebe multipart com payload JSON + audio
#   6. Ao publicar a transcricao, o audio temporario e removido do disco

# Tokens validos pra o helper local de download de audio
# (script /helper que roda no PC do admin pra baixar do YouTube com IP
# residencial e fazer upload pro portal). Multiplos tokens separados
# por virgula — util pra rotacionar ou ter helpers em maquinas dif.
# Gere com: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
HELPER_TOKENS=

# Whisper local (faster-whisper)
# Instale no servidor: pip install faster-whisper
WHISPER_MODEL=large-v3
WHISPER_PYTHON_PATH=python3
# Imprime logs do whisper no stderr do servidor (util pra debug)
WHISPER_VERBOSE=false

# Pasta onde os audios uploadados ficam salvos.
# DEFAULT: ./uploads/audios/ no cwd do processo Node.
# O audio e temporario: fica aqui ate a transcricao ser publicada.
AUDIO_STORAGE_PATH=

# Pasta onde os videos completos (para recortes/Shorts) ficam salvos.
# DEFAULT: ./uploads/videos/ no cwd do processo Node.
# O video e temporario: fica aqui ate os clips serem gerados.
VIDEO_STORAGE_PATH=
# Apagar o audio automaticamente ao PUBLICAR a transcricao (comportamento antigo).
# Default false: a midia NAO e apagada na publicacao (para nao quebrar os recortes).
# Exclua manualmente pelo botao "Excluir midia" na tela da transcricao.
DELETE_MEDIA_ON_PUBLISH=false
# Limite (MB) do upload de video vindo do helper. Default 2048 (2GB).
HELPER_VIDEO_UPLOAD_LIMIT_MB=2048

# Webhook de transcricao:
# Configure no modulo de Webhooks do admin usando o evento:
# - transcript.completed
# O envio e multipart/form-data com payload JSON + audio (quando existir).

# Filtros aplicados ao sincronizar vídeos do YouTube
# Apenas vídeos públicos (não inclui unlisted nem private)
SYNC_ONLY_PUBLIC=true
# Duração mínima em segundos (900 = 15 min). 0 = sem filtro de duração
SYNC_MIN_DURATION_SECONDS=900

# Sincronização automática semanal dos canais do YouTube (timezone America/Campo_Grande)
# Default: segunda-feira (1) à meia-noite (0h)
# Domingo=0, Segunda=1, Terça=2, ..., Sábado=6
YOUTUBE_SYNC_ENABLED=true
YOUTUBE_SYNC_DAY=1
YOUTUBE_SYNC_HOUR=0

# Worker de transcricao - janela horaria semanal (timezone America/Sao_Paulo)
# Default: terca-feira (2) das 00h as 06h, max 6h de processamento
TRANSCRIPT_WORKER_ENABLED=true
TRANSCRIPT_WORKER_DAY=2
TRANSCRIPT_WORKER_HOUR_START=0
TRANSCRIPT_WORKER_HOUR_END=6
TRANSCRIPT_WORKER_MAX_HOURS=6

# ===== Embeddings semânticos (busca bíblica) =====
# false = desativa o servidor Python de embeddings (útil em desenvolvimento para economizar memória).
# A busca bíblica continua funcionando, mas sem filtro semântico — retorna todos os candidatos da API.
EMBEDDING_ENABLED=true

# ===== Módulo Bíblia =====
# Token gratuito da API A Bíblia Digital (cadastro por email em https://www.abibliadigital.com.br/)
BIBLE_API_TOKEN=
# Versão padrão (nvi, acf, ra, etc.)
BIBLE_DEFAULT_VERSION=nvi

# ===== Provedor de LLM (módulo Bíblia) =====
# Provedor ativo: gemini | groq | claude
LLM_PROVIDER=gemini
# Google AI Studio (tier gratuito) — https://ai.google.dev/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Groq (gratuito) — https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Anthropic Claude (pago) — ANTHROPIC_API_KEY já pode existir acima
ANTHROPIC_MODEL=claude-sonnet-4-6

# ===== Resumo de vídeo (fallback multi-provedor) =====
# Ordem de tentativa no resumo do vídeo para publicação. Tenta cada um em sequência
# e cai para o próximo se falhar. Provedores válidos: groq | grok | gemini | claude
# Padrão: gratuitos primeiro, Claude (pago) como último recurso.
VIDEO_SUMMARY_PROVIDERS=groq,gemini,claude
# xAI Grok (opcional) — https://console.x.ai/ — use GROK_API_KEY ou XAI_API_KEY
GROK_API_KEY=
GROK_MODEL=grok-2-latest
# Overrides de modelo por provedor no resumo (opcionais; usam os defaults acima se vazios)
# VIDEO_SUMMARY_GROQ_MODEL=
# VIDEO_SUMMARY_GEMINI_MODEL=
# VIDEO_SUMMARY_GROK_MODEL=
# VIDEO_SUMMARY_CLAUDE_MODEL=

# ===== Selecao de recortes/Shorts (Fase 3) =====
# Cadeia de LLM para escolher os momentos (default reaproveita VIDEO_SUMMARY_PROVIDERS).
# LLM_CHAIN_PROVIDERS=groq,gemini,claude
# Quantidade e duracao dos recortes sugeridos pela IA (teto absoluto: 5).
CLIP_MIN_COUNT=2
CLIP_MAX_COUNT=5
CLIP_MIN_SECONDS=15
CLIP_MAX_SECONDS=75

# ===== Render dos recortes (Fase 4: ffmpeg + rastreamento de rosto) =====
# REQUISITOS no servidor:
#   - ffmpeg/ffprobe no PATH (ou defina FFMPEG_PATH/FFPROBE_PATH),
#     OU instale os binarios bundled: npm i ffmpeg-static ffprobe-static
#   - Para o rastreamento de rosto: pip install opencv-python-headless
#     (sem ele, o corte cai para crop central estatico automaticamente)
# FFMPEG_PATH=
# FFPROBE_PATH=
# Python para o face_track (default reaproveita WHISPER_PYTHON_PATH).
# FACE_TRACK_PYTHON_PATH=
# Pasta dos arquivos de clip gerados (default ./uploads/clips/).
CLIP_STORAGE_PATH=
# Qualidade/velocidade do encode (preset libx264 e CRF).
CLIP_FFMPEG_PRESET=veryfast
CLIP_FFMPEG_CRF=20
# Timeout do render de um clip (ms).
CLIP_RENDER_TIMEOUT_MS=600000

# ===== Publicacao de Shorts (Fase 5: videos.insert) =====
# IMPORTANTE: foi adicionado o escopo youtube.upload ao OAuth. Canais conectados
# ANTES desta mudanca precisam RECONECTAR (re-autorizar) para poder publicar.
# categoryId padrao do Short (22 = People & Blogs; 27 = Education).
CLIP_SHORTS_CATEGORY_ID=22
