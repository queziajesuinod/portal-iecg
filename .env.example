# Ambiente
NODE_ENV=development

# Banco de Dados PostgreSQL
DB_USER=root
DB_PASS=sua_senha_aqui
DB_NAME=iecg_bd
DB_HOST=localhost
DB_PORT=5432
DB_SCHEMA=dev_iecg

# JWT
JWT_SECRET=sua_chave_secreta_jwt

# API URL
REACT_APP_API_URL=http://localhost:3005

# Cielo E-commerce API
# Obtenha suas credenciais em: https://cadastrosandbox.cieloecommerce.cielo.com.br/
CIELO_MERCHANT_ID=seu_merchant_id_aqui
CIELO_MERCHANT_KEY=sua_merchant_key_aqui
CIELO_ENVIRONMENT=sandbox
# Valores possíveis: 'sandbox' (testes) ou 'production' (produção)

# Evolution API (WhatsApp)
# Configure sua instância da Evolution API para envio de notificações
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key_aqui
EVOLUTION_INSTANCE_NAME=iecg-events

# Frontend URL (para links nas notificações)
FRONTEND_URL=http://localhost:3000

# Observações:
# - Para ambiente de testes (sandbox), use as credenciais fornecidas pela Cielo Sandbox
# - Para produção, solicite credenciais reais no portal da Cielo
# - Configure a Evolution API para receber notificações via WhatsApp
# - Nunca commite este arquivo com credenciais reais no repositório

# Ef� Pay
EFI_ENVIRONMENT=sandbox
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_CERTIFICATE_PATH=path/para/certificado.pfx  # ou use EFI_CERTIFICATE_BASE64 para certificados em base64
EFI_PEM_KEY_PATH=path/para/chave.pem  # ou use EFI_PEM_KEY_BASE64 para chave em base64
EFI_PARTNER_TOKEN=
EFI_CACHE_TOKEN=true
EFI_VALIDATE_MTLS=true
EFI_COMMISSION_PERCENT=1.5
EFI_PIX_PAGADOR_CHAVE=
EFI_PIX_FAVORECIDO_CHAVE=
EFI_PIX_INFO_PAGADOR=Comiss�o Ef�
EFI_PIX_ID_PREFIX=efi-commission


# Redis (Cache)
# URL de conexão do Redis para cache de performance
# Deixe vazio ou comente para desabilitar o cache (sistema funcionará normalmente)
REDIS_URL=redis://localhost:6379

# ===== Modulo de transcricao de videos do YouTube =====
# Credenciais OAuth do Google (um par para o portal inteiro, atende N canais)
# Crie em https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client IDs)
# Habilite a "YouTube Data API v3" no projeto antes
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://portal.iecg.com.br/api/public/youtube/oauth/callback

# Chave para criptografar refresh tokens de canais no banco (AES-256-GCM)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# Anthropic Claude (usado para gerar resumos das transcricoes)
ANTHROPIC_API_KEY=

# Whisper local (faster-whisper) - usado como ULTIMO recurso quando nem caption
# manual nem youtube-transcript conseguem obter transcricao.
# Instale no servidor: pip install faster-whisper yt-dlp
WHISPER_MODEL=large-v3
WHISPER_PYTHON_PATH=python3
# Imprime logs do whisper no stderr do servidor (util pra debug)
WHISPER_VERBOSE=false

# ===== Pipeline de transcricao =====
# Ordem de tentativa (primeiro que retornar texto vence):
#   1. Caption manual via YouTube Data API (OAuth, so videos do canal autorizado)
#   2. youtube-transcript (npm, pega manual ou auto-gerada do endpoint timedtext)
#   3. yt-dlp + Whisper local (fallback final, lento e pesado)
# A etapa 2 nao precisa de instalacao extra - a dependencia "youtube-transcript"
# ja esta no package.json e instala junto com npm install.
# Path do yt-dlp (deixe vazio se estiver no PATH)
YT_DLP_PATH=yt-dlp
# JS runtime usado pelo yt-dlp pra decodificar signatures do YouTube
# Sem isso, cai no cliente "android vr" que é bloqueado pelo anti-bot
# Opções: node, deno, jsdom (default: node, já vem na imagem)
YT_DLP_JS_RUNTIME=node
# Seletor de formato. DEIXE VAZIO pra o servico fazer discovery dinamico
# (chama yt-dlp --dump-single-json antes, escolhe o melhor audio-only disponivel
# pelo bitrate/ext, e baixa pelo format_id exato). Mais robusto contra videos
# que nao tem todos os formatos padroes.
# So preencha se quiser forcar um seletor especifico (ex: "bestaudio/best").
YT_DLP_FORMAT=
# OPCIONAL: força player clients específicos (deixar vazio = yt-dlp escolhe)
# Use só se anti-bot bloquear. Exemplos:
#   web,tv,tv_simply,web_safari       (recomendado em VPS com cookies)
#   tv_simply,web_safari               (alternativa quando web bloqueia)
YT_DLP_PLAYER_CLIENTS=
# ---- PO Token (Proof of Origin) ----
# Em VPS, cookies sozinhos nao bastam: o YouTube exige tambem um PO Token
# vinculado ao visitor_data da sessao. Sem ele, da "Sign in to confirm you're
# not a bot". A solucao recomendada e rodar o bgutil-ytdlp-pot-provider como
# sidecar HTTP e instalar o plugin equivalente no yt-dlp.
#
# Setup rapido (rode em server/scripts/setup-pot-provider.sh):
#   docker run --name bgutil-provider --restart unless-stopped \
#     -d --init -p 4416:4416 brainicism/bgutil-ytdlp-pot-provider
#   pip install -U bgutil-ytdlp-pot-provider yt-dlp
#
# O plugin se conecta sozinho em http://127.0.0.1:4416. Pra apontar pra outra
# URL (ex: container em outra maquina), descomente e ajuste:
# YT_DLP_EXTRA_ARGS=--extractor-args youtube:bgutil_baseurl=http://127.0.0.1:4416
# OPCIONAL: user-agent customizado (deixar vazio = yt-dlp escolhe)
# Use só se quiser fingir um navegador específico
YT_DLP_USER_AGENT=
# Path da pasta do ffmpeg (deixe vazio se ffmpeg estiver no PATH)
# Windows exemplo: C:/Users/Seu/AppData/Local/Microsoft/WinGet/Packages/Gyan.FFmpeg.../bin
FFMPEG_PATH=

# Filtros aplicados ao sincronizar vídeos do YouTube
# Apenas vídeos públicos (não inclui unlisted nem private)
SYNC_ONLY_PUBLIC=true
# Duração mínima em segundos (900 = 15 min). 0 = sem filtro de duração
SYNC_MIN_DURATION_SECONDS=900

# Sincronização automática semanal dos canais do YouTube (timezone America/Campo_Grande)
# Default: segunda-feira (1) à meia-noite (0h)
# Domingo=0, Segunda=1, Terça=2, ..., Sábado=6
YOUTUBE_SYNC_ENABLED=true
YOUTUBE_SYNC_DAY=1
YOUTUBE_SYNC_HOUR=0

# Worker de transcricao - janela horaria semanal (timezone America/Sao_Paulo)
# Default: terca-feira (2) das 00h as 06h, max 6h de processamento
TRANSCRIPT_WORKER_ENABLED=true
TRANSCRIPT_WORKER_DAY=2
TRANSCRIPT_WORKER_HOUR_START=0
TRANSCRIPT_WORKER_HOUR_END=6
TRANSCRIPT_WORKER_MAX_HOURS=6
