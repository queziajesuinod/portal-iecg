# URL do portal IECG (sem barra no final)
PORTAL_URL=https://portal.iecg.com.br

# Token compartilhado — DEVE bater com um dos itens em HELPER_TOKENS
# no .env do servidor. Gere com: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
HELPER_TOKEN=

# Intervalo entre verificacoes da fila (ms). Default 60s.
POLL_INTERVAL_MS=60000

# Quantos videos processar a cada ciclo. Mantem 1 pra nao saturar
# upload nem CPU local.
MAX_PER_TICK=1

# Bitrate do MP3 baixado (kbps). 64 = ~28MB/h, 96 = ~42MB/h, 128 = ~56MB/h.
# Pra pregacao 64 ja basta, mas 96 da mais margem se a qualidade
# do video for ruim.
AUDIO_BITRATE=96

# Pasta temporaria pra arquivos baixados antes do upload.
# Default usa o tmp do sistema (apagado no reboot).
# TMP_DIR=

# Baixar tambem o VIDEO completo (alem do audio) para gerar recortes/Shorts
# no portal. Deixe "true" so nos canais/maquinas onde voce quer os clips —
# o video e bem maior que o audio (mais banda de upload).
HELPER_DOWNLOAD_VIDEO=false
# Altura maxima do video baixado (720 = HD, suficiente pra Shorts 9:16).
# Menor = arquivo menor e upload mais rapido.
VIDEO_MAX_HEIGHT=720

# ===== REQUISITO: Deno (runtime JS para o "n challenge" do YouTube) =====
# Sem um runtime JS, o yt-dlp recente falha com "Requested format is not available"
# (o YouTube devolve so miniaturas). Instale o Deno UMA vez:
#   Windows: irm https://deno.land/install.ps1 | iex
#   Linux/VPS: curl -fsSL https://deno.land/install.sh | sh
# O helper procura automaticamente em ~/.deno/bin. Se instalou em outro lugar, aponte:
# DENO_BIN_DIR=/caminho/para/deno/bin

# ===== Autenticacao do yt-dlp (resolve "Sign in to confirm you're not a bot") =====
# O YouTube passou a bloquear downloads anonimos. Autentique o yt-dlp com cookies
# de uma conta logada no YouTube. Escolha UMA das opcoes:
#
# OPCAO 1 (recomendada): arquivo cookies.txt exportado do navegador.
#   - Instale a extensao "Get cookies.txt LOCALLY" no Chrome/Firefox,
#     abra youtube.com logado e exporte o cookies.txt.
#   - Aponte o caminho do arquivo aqui. Nao precisa manter o navegador aberto.
# YTDLP_COOKIES_FILE=C:\caminho\para\cookies.txt
#
# OPCAO 2: ler cookies direto do navegador local (mais pratico, menos estavel).
#   Valores: chrome | edge | firefox | brave | opera | vivaldi
#   Obs.: no Windows, feche o navegador antes de rodar (ele trava o arquivo de cookies).
#   NAO funciona no VPS (nao tem navegador) — no VPS use a OPCAO 1 (arquivo).
# YTDLP_COOKIES_FROM_BROWSER=chrome

# ===== Rodar o helper no VPS =====
# O IP do VPS e de datacenter e o YouTube bloqueia mais nesses IPs. Para rodar no VPS:
#   1) Use YTDLP_COOKIES_FILE (suba o cookies.txt pro VPS) — cookies-from-browser nao funciona la.
#   2) Se AINDA bloquear, roteie por um PROXY RESIDENCIAL (servico pago).
# PROXY do yt-dlp. Formato: http://user:senha@host:porta  ou  socks5://host:porta
# YTDLP_PROXY=

# OPCIONAL: filtra por um canal especifico (UUID interno, vindo da
# tabela youtube_channels.id). Se deixar vazio, o helper mostra um
# seletor interativo no startup. Util pra rodar como servico/cron com
# canal pre-fixado.
# CHANNEL_ID=
# CHANNEL_NAME=IECG  (so pro log, opcional)

# OPCIONAL: para apos baixar/enviar N videos. 0 = sem limite.
# Se deixar vazio (e nao tiver CHANNEL_ID), o helper pergunta no startup.
# MAX_VIDEOS_TOTAL=10
